# Copy to .env.local and fill in. Names only — never commit values.

# Public site origin used for canonical URLs, OG tags, sitemap, referral links.
NEXT_PUBLIC_SITE_URL=

# Supabase (server)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (server)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=

# Token signing secret for verify/unsubscribe links (server)
EMAIL_TOKEN_SECRET=

# PostHog (client)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
